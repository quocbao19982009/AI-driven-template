{
  // Hook for Github copilot to block edits to auto-generated files and remind about spec sync when editing backend feature files
  "deny": {
    "message": "Your edit was blocked by a pre-tool hook. Please see the details for more information."
  },
  "hooks": {
    // Runs before every edit/write — blocks manual changes to Orval-generated files.
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys, json; d=json.load(sys.stdin); fp=d.get('file_path',''); blocked='api/generated/' in fp; print('BLOCK: Files under api/generated/ are auto-generated by Orval and must not be edited manually. Run npm run api:sync instead.') if blocked else None; sys.exit(2 if blocked else 0)\"",
            "timeout": 5000
          }
        ]
      }
    ],
    // Runs after every edit — reminds to update the feature spec when backend files change.
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys, json, re; d=json.load(sys.stdin); fp=d.get('file_path',''); m=re.search(r'Features/([^_][^/]+)/(.*Service|.*Controller|.*Validator|.*Repository)\\.cs$', fp); print('Reminder: You edited a backend feature file in ' + m.group(1) + '. If behavior changed, update the feature spec via the spec-sync agent.') if m else None; sys.exit(0)\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
