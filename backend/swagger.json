                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Revoke the refresh token and clear the cookie. Returns 204 No Content.",
        "responses": {
