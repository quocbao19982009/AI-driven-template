# JWT signing key — REQUIRED in all environments
# Must be at least 32 characters. Never commit a real value here.

# Local development (dotnet user-secrets):
#   dotnet user-secrets set "Jwt:Key" "your-secure-random-key-here-32plus"

# CI/CD / production (environment variable, __ = JSON hierarchy separator):
#   Jwt__Key=your-secure-random-key-here-32plus
