{
  "cSpell.words": ["Serilog"],
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true,
    "**/api/generated/**": true
  },
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "i18n-ally.localesPaths": ["frontend/src/locales"],
  "i18n-ally.keystyle": "nested",
  "i18n-ally.sourceLanguage": "en",
  "i18n-ally.displayLanguage": "en",
  "i18n-ally.enabledFrameworks": ["react-i18next"],
  "i18n-ally.namespace": false,
  // Github Copilot setting (mirror Claude Code)
  // Right now I don't see anyway to block Github Copilot from reading secert file
  "chat.tools.terminal.autoApprove": {
    "/^dotnet ef database (update|drop)/i": false,
    "/^dotnet ef migrations remove\\b/i": false
  },
  "chat.tools.edits.autoApprove": {
    "**/.env": false,
    "**/.vscode/*.json": false
  },
  // Link to Claude Hooks: More infomation here https://code.visualstudio.com/docs/copilot/customization/hooks
  "chat.hookFilesLocations": {
    ".github/hooks": true,
    ".claude/settings.local.json": true,
    ".claude/settings.json": true,
    "~/.claude/settings.json": true
  }
}
